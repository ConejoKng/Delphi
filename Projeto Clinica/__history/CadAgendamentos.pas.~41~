unit CadAgendamentos;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.Buttons, Vcl.DBCtrls, Vcl.StdCtrls,
  Vcl.ExtCtrls, Vcl.Mask, Data.DB, Vcl.Grids, Vcl.DBGrids;

type
  TformCadAgendamentos = class(TForm)
    Panel1: TPanel;
    Label1: TLabel;
    Button1: TButton;
    Button2: TButton;
    Button3: TButton;
    GroupBox1: TGroupBox;
    Label3: TLabel;
    Label5: TLabel;
    Label6: TLabel;
    Label7: TLabel;
    Panel2: TPanel;
    SpeedButton1: TSpeedButton;
    Label2: TLabel;
    txtMedico: TEdit;
    Label4: TLabel;
    txtBusca: TEdit;
    DBGrid1: TDBGrid;
    txtId: TEdit;
    especialidadeBox: TComboBox;
    txtData: TMaskEdit;
    txtHora: TMaskEdit;
    Button4: TButton;
    Button5: TButton;
    procedure Button3Click(Sender: TObject);
    procedure Button2Click(Sender: TObject);
    procedure limparCampos;
    procedure FormCreate(Sender: TObject);
    procedure SpeedButton1Click(Sender: TObject);
    procedure Button1Click(Sender: TObject);
    function validarCampos: Boolean;
    procedure Button4Click(Sender: TObject);
    procedure txtBuscaChange(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  formCadAgendamentos: TformCadAgendamentos;

implementation

{$R *.dfm}

uses unitDM, UnitViewAgendamento;

procedure TformCadAgendamentos.Button1Click(Sender: TObject);
begin
  if validarCampos then
    begin
      DM.insertAgendamento.ParamByName('ID_PACIENTE').AsInteger := StrToInt(txtId.Text);
      DM.insertAgendamento.ParamByName('DATA').AsDate := StrToDate(txtData.Text);
      DM.insertAgendamento.ParamByName('HORA').AsString := txtHora.Text;
      DM.insertAgendamento.ParamByName('ESPECIALIDADE').AsString := especialidadeBox.Items[especialidadeBox.ItemIndex];
      DM.insertAgendamento.ParamByName('MEDICO').AsString := txtMedico.Text;
      DM.insertAgendamento.ExecSQL;
      DM.insertAgendamento.Close;
      ShowMessage('Agendamento Cadastrado com Sucesso!')
    end;
end;

procedure TformCadAgendamentos.Button2Click(Sender: TObject);
begin
  Close;
end;

procedure TformCadAgendamentos.Button3Click(Sender: TObject);
begin
  if (Trim(txtId.Text) = '') or (Trim(txtData.Text) = '') or (Trim(txtHora.Text) = '') or (especialidadeBox.ItemIndex = -1) then
  begin
    ShowMessage('Preencha o campos corretamente')
  end
  else
  begin

  end;

end;

procedure TformCadAgendamentos.Button4Click(Sender: TObject);
begin
    Application.CreateForm(TViewAgendamentos, ViewAgendamentos);
    ViewAgendamentos.ShowModal;
end;

procedure TformCadAgendamentos.FormCreate(Sender: TObject);
begin
  dm.tdPaciente.Open;
  limparCampos
end;

procedure TformCadAgendamentos.limparCampos;
begin
  txtId.Clear;
  txtData.Clear;
  txtHora.Clear;
  especialidadeBox.ItemIndex := -1;
  txtMedico.Clear;
end;


procedure TformCadAgendamentos.SpeedButton1Click(Sender: TObject);
begin
  Close;
end;

procedure TformCadAgendamentos.txtBuscaChange(Sender: TObject);
var
  id: integer;
begin
  if TryStrToInt(txtBusca.Text, id) then
    begin
      DM.tdPaciente.close;
      DM.tdPaciente.SQL.Text := ('SELECT * FROM PACIENTE WHERE ID = :ID');
      DM.tdPaciente.ParamByName('ID').AsInteger := id;
      DM.tdPaciente.Open;
    end
  else
    begin
      DM.tdPaciente.close;
      DM.tdPaciente.SQL.Text := ('SELECT * FROM PACIENTE WHERE NOME LIKE :NOME');
      DM.tdPaciente.ParamByName('NOME').AsString := '%' + txtBusca.Text + '%';
      DM.tdPaciente.Open;
    end;
  if Trim(txtBusca.Text) = '' then
  begin
    DM.tdPaciente.Close;
    DM.tdPaciente.Open;
    exit
  end;
end;

function TformCadAgendamentos.validarCampos: Boolean;
var
  resultado: Boolean;
begin
  if (Trim(txtId.Text) = '') or (Trim(txtData.Text) = '') or (Trim(txtHora.Text) = '') or (especialidadeBox.ItemIndex = -1) or (Trim(txtMedico.Text) = '') then
    begin
      ShowMessage('Preencha todos os campos Corretamente!');
      resultado := False;
    end;
  if (Trim(txtId.Text) <> '') and (Trim(txtData.Text) <> '') and (Trim(txtHora.Text) <> '') and (especialidadeBox.ItemIndex <> -1) and (Trim(txtMedico.Text) <> '') then
  begin
    resultado := True;
  end;

  Result := resultado;
end;

end.
